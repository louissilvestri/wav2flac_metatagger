# Music Manager — API keys template
# Copy this file to .env and fill in your values. .env is gitignored.

# MusicBrainz: no key needed, just a contact email for the user agent
MUSICBRAINZ_CONTACT=you@example.com

# Discogs: https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# AcoustID: https://acoustid.org/new-application
ACOUSTID_API_KEY=

# Last.fm: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# fanart.tv: https://fanart.tv/get-an-api-key/
FANARTTV_API_KEY=

# TheAudioDB: public test key "2" works for the free tier
THEAUDIODB_API_KEY=2

# iTunes Search API and Deezer API require no key.
